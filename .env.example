# ---- Get this from @BotFather on Telegram ----
BOT_TOKEN=123456:ABC-DEF1234567890

# ---- Your bot's username WITHOUT the @ ----
BOT_USERNAME=YourFileStoreBot

# ---- MongoDB connection string from https://cloud.mongodb.com (free M0 cluster) ----
MONGO_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
DB_NAME=FileStoreBot

# ---- Numeric ID of a PRIVATE channel where the bot is admin (files get stored here) ----
# Forward a TEXT message from that channel to the bot itself (as an admin) to get the exact ID.
DB_CHANNEL=-1001234567890

# ---- Comma separated Telegram user IDs who get admin access ----
ADMINS=111111111,222222222

# ---- Comma separated channel USERNAMES (no @) users must join. Leave empty to disable ----
FORCE_SUB_CHANNELS=

# ---- Optional: an image URL shown on /start ----
START_PIC=

# ---- Render sets this automatically, safe to leave as is ----
PORT=8080
